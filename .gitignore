# ============================================
# GeM Scraper — .gitignore
# ============================================
# This file tells Git which files/folders to ignore.
# Ignored files won't be tracked or committed.

# ============================================
# Python Bytecode & Cache
# ============================================
# Python compiles .py files to .pyc bytecode for faster loading.
# These are machine-specific and should never be committed.
__pycache__/
*.py[cod]
*$py.class

# ============================================
# Distribution / Packaging
# ============================================
# Created when you build or package your project
build/
dist/
*.egg-info/
*.egg

# ============================================
# Virtual Environments
# ============================================
# venv contains all installed packages — each developer creates their own
venv/
.venv/
env/
ENV/

# ============================================
# Environment Variables
# ============================================
# .env contains secrets and local config — NEVER commit this!
# .env.example is the template and IS committed (no secrets in it)
.env

# ============================================
# IDE / Editor Settings
# ============================================
# These are personal editor preferences, not project config
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================
# Project Output
# ============================================
# Scraped data, processed files, screenshots — all generated, not source code
output/
screenshots/

# ============================================
# Data Files
# ============================================
# CSV and JSON outputs are generated by the scraper.
# We exclude them to keep the repo clean and lightweight.
*.csv
*.json

# EXCEPTION: package.json is used by some tools and should be tracked
!package.json

# ============================================
# Logs
# ============================================
*.log
logs/

# ============================================
# Playwright
# ============================================
# Playwright may download browser binaries — don't commit those
playwright-report/
test-results/

# ============================================
# Miscellaneous
# ============================================
*.bak
*.tmp
*.temp
